{
  "name": "oman-sale",
  "version": "0.1.0",
  "private": true,
  "description": "Oman Sale universal listing platform monorepo.",
  "packageManager": "npm@10.0.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "prisma:generate": "npm --workspace @oman-sale/api run prisma:generate",
    "prisma:migrate": "npm --workspace @oman-sale/api run prisma:migrate",
    "prisma:deploy": "npm --workspace @oman-sale/api run prisma:deploy",
    "jobs:dev": "npm --workspace @oman-sale/jobs run dev",
    "jobs:start": "npm --workspace @oman-sale/jobs run start",
    "mobile:dev": "npm --workspace @oman-sale/mobile run dev",
    "mobile:dev:clear": "npm --workspace @oman-sale/mobile run dev:clear",
    "mobile:eas:init": "npm --workspace @oman-sale/mobile run eas:init",
    "mobile:credentials:android": "npm --workspace @oman-sale/mobile run credentials:android",
    "mobile:build:apk": "npm --workspace @oman-sale/mobile run build:android:preview",
    "mobile:build:apk:production": "npm --workspace @oman-sale/mobile run build:android:production"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "@oman-sale/mobile": {
      "zustand": "5.0.13",
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "react-freeze": {
        "react": "19.1.0"
      },
      "use-sync-external-store": {
        "react": "19.1.0"
      }
    },
    "react-freeze": {
      "react": "19.1.0"
    },
    "use-sync-external-store": {
      "react": "19.1.0"
    }
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "turbo": "^2.0.14",
    "typescript": "^5.5.4"
  }
}
