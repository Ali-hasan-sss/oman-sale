{
  "name": "oman-sale",
  "version": "0.1.0",
  "private": true,
  "description": "Oman Sale universal listing platform monorepo.",
  "packageManager": "npm@10.0.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "prisma:generate": "npm --workspace @oman-sale/api run prisma:generate",
    "prisma:migrate": "npm --workspace @oman-sale/api run prisma:migrate",
    "prisma:deploy": "npm --workspace @oman-sale/api run prisma:deploy",
    "jobs:dev": "npm --workspace @oman-sale/jobs run dev",
    "jobs:start": "npm --workspace @oman-sale/jobs run start"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "turbo": "^2.0.14",
    "typescript": "^5.5.4"
  }
}
