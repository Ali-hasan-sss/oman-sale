{
  "name": "@oman-sale/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "dev": "expo start",
    "dev:clear": "expo start --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "eas:init": "eas init",
    "credentials:android": "eas credentials -p android",
    "build:android:preview": "eas build -p android --profile preview",
    "build:android:production": "eas build -p android --profile production",
    "build:android:preview:ci": "eas build -p android --profile preview --non-interactive",
    "build:android:production:ci": "eas build -p android --profile production --non-interactive"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@expo-google-fonts/cairo": "^0.4.2",
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native/virtualized-lists": "^0.81.5",
    "axios": "^1.7.4",
    "expo": "~54.0.34",
    "expo-av": "~16.0.8",
    "expo-build-properties": "^0.14.8",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.7",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "^3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.16.0",
    "socket.io-client": "^4.8.3",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "^5.5.4"
  }
}
