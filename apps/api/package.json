{
  "name": "@oman-sale/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "node scripts/prisma.cjs generate",
    "prisma:migrate": "node scripts/prisma.cjs migrate dev --name auto",
    "prisma:deploy": "node scripts/prisma.cjs migrate deploy",
    "prisma:seed": "node prisma/seed.cjs",
    "prisma:seed:tsx": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.7.4",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.8",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.7",
    "pg": "^8.16.3",
    "prisma": "7.8.0",
    "slugify": "^1.6.6",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.15",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.15.6",
    "tsx": "^4.16.5"
  }
}
