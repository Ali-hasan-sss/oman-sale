NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000
HOST=0.0.0.0
# Set to 1 when the API is behind one local Nginx reverse proxy.
# This makes req.ip use X-Forwarded-For so rate limits and views use the real client IP.
TRUST_PROXY=1
# Comma-separated extra browser origins (optional)
# CORS_ORIGINS=http://192.168.1.10:3000
# Allow LAN/private IPs in development (default true). Set false to disable.
# CORS_ALLOW_LAN_IN_DEV=true

# --- Frontend: put in apps/web/.env (PC uses localhost; phone uses same IP as :3000 automatically) ---
# NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
# For same-origin Nginx deployment, use:
# NEXT_PUBLIC_API_URL=/api/v1
# NEXT_PUBLIC_API_PORT=4000
# NEXT_PUBLIC_CONTACT_EMAIL=info@omansale.om
# NEXT_PUBLIC_CONTACT_PHONE=+968 2456 7890

DATABASE_URL=postgresql://oman_sale:oman_sale@127.0.0.1:55432/oman_sale?schema=public
SHADOW_DATABASE_URL=postgresql://oman_sale:oman_sale@127.0.0.1:55432/oman_sale_shadow?schema=public
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

PASSWORD_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

MEDIA_PROVIDER=local

# Email auth codes. Keep true locally to avoid sending emails and use 000000.
EMAIL_SKIP_SEND=true
EMAIL_SKIP_CODE=000000
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Oman Sale <no-reply@omansale.local>"

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
AWS_REGION=
AWS_S3_BUCKET=
